<alfresco-config>
    <config evaluator="string-compare" condition="DocLibActions">
        <actions>
            <action id="ejc-publish-web-workflow" type="javascript" label="Publish to Web">
                <param name="function">onActionPublishWebWorkflow</param>
            </action>
            <action id="ejc-unpublish-web-workflow" type="javascript" label="ActionUnpublishWebWorkflow">
                <param name="function">onActionUnpublishWebWorkflow</param>
            </action>
        </actions>
        <actionGroups>
            <actionGroup id="document-browse">
                <action index="400" id="ejc-publish-web-workflow" />
                <action index="401" id="ejc-unpublish-web-workflow" />
            </actionGroup>
        </actionGroups>
    </config>

    <config evaluator="string-compare" condition="WorkflowConfig">
        <workflows>
            <workflow id="activiti$publishWeb" label="Publish Web" />
            <workflow id="activiti$unpublishWeb" label="Unpublish Web" />
        </workflows>
    </config>
</alfresco-config>